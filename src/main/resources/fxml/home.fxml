<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="10.0" xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.PL.pig_ranch.controller.HomeController">
    <children>
        <Label text="Pig Ranch Management" styleClass="home-title"/>

        <!-- Actions -->
        <Label text="ACTIONS" styleClass="home-section-label"/>
        <Button text="New Order" onAction="#handleNewOrderClick"
                styleClass="home-nav-btn, btn-primary"/>

        <Separator styleClass="home-separator"/>

        <!-- Browse -->
        <Label text="BROWSE" styleClass="home-section-label"/>
        <Button text="Clients" onAction="#handleClientsClick"
                styleClass="home-nav-btn, btn-secondary"/>
        <Button text="Inventory" onAction="#handleInventoryClick"
                styleClass="home-nav-btn, btn-secondary"/>
        <Button text="Pending Orders" onAction="#handlePendingOrdersClick"
                styleClass="home-nav-btn, btn-warning"/>
        <Button text="Order History" onAction="#handleOrderHistoryClick"
                styleClass="home-nav-btn, btn-secondary"/>
    </children>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>
</VBox>
