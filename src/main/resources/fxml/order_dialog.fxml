<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="15" xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.PL.pig_ranch.controller.OrderDialogController"
      prefWidth="650" prefHeight="650">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label fx:id="titleLabel" text="New Order" styleClass="dialog-title"/>

    <!-- Client + Status -->
    <GridPane hgap="10" vgap="10">
        <columnConstraints>
            <ColumnConstraints minWidth="100" prefWidth="120"/>
            <ColumnConstraints hgrow="ALWAYS"/>
            <ColumnConstraints minWidth="80" prefWidth="100"/>
        </columnConstraints>

        <Label text="Client:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <ComboBox fx:id="clientComboBox" maxWidth="Infinity" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
        <Button text="New Client" onAction="#handleNewClientClick" GridPane.rowIndex="0" GridPane.columnIndex="2"
                styleClass="btn-info" fx:id="newClientButton"/>

        <Label text="Payment:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <CheckBox fx:id="paidCheckBox" text="Is Paid" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Shipping:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <CheckBox fx:id="shippedCheckBox" text="Is Shipped" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Notes:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <TextArea fx:id="notesArea" prefHeight="50" GridPane.rowIndex="3" GridPane.columnIndex="1"
                  GridPane.columnSpan="2"/>

        <Label text="Order Discount ($):" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <TextField fx:id="globalDiscountField" promptText="e.g. 10.00" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
    </GridPane>

    <!-- Order Items (always visible) -->
    <VBox spacing="8" VBox.vgrow="ALWAYS">
        <Label text="Order Items" style="-fx-font-weight: bold; -fx-font-size: 14;"/>
        <TableView fx:id="itemTable" prefHeight="180" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colItemName" text="Item" prefWidth="250"/>
                <TableColumn fx:id="colItemQuantity" text="Qty" prefWidth="80"/>
                <TableColumn fx:id="colItemPrice" text="Unit Price" prefWidth="100"/>
                <TableColumn fx:id="colItemDiscount" text="Discount" prefWidth="80"/>
                <TableColumn fx:id="colActions" text="Actions" prefWidth="80"/>
            </columns>
        </TableView>
        <HBox spacing="10">
            <Button text="Add Item" onAction="#handleAddItem" fx:id="addItemButton"
                    styleClass="btn-primary"/>
        </HBox>
    </VBox>

    <!-- Hog Details (collapsible) -->
    <TitledPane fx:id="hogTitledPane" text="Hog Details" expanded="false">
        <GridPane hgap="10" vgap="10">
            <columnConstraints>
                <ColumnConstraints minWidth="100" prefWidth="120"/>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>

            <Label text="Hog Number:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <TextField fx:id="hogNumberField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

            <Label text="Hog Type:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <ComboBox fx:id="hogTypeComboBox" maxWidth="Infinity" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

            <Label text="Processor:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <TextField fx:id="processorField" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

            <Label text="Live Weight:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
            <TextField fx:id="liveWeightField" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

            <Label text="Hanging Weight:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
            <TextField fx:id="hangingWeightField" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

            <Label text="Processing Cost:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
            <TextField fx:id="processingCostField" GridPane.rowIndex="5" GridPane.columnIndex="1"/>

            <CheckBox fx:id="inspectedCheckBox" text="Inspected" GridPane.rowIndex="6" GridPane.columnIndex="1"/>
        </GridPane>
    </TitledPane>

    <!-- Action Buttons -->
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Cancel" onAction="#handleCancel" prefWidth="80"/>
        <Button text="Save" onAction="#handleSave" prefWidth="80" fx:id="saveButton"
                styleClass="btn-primary"/>
    </HBox>
</VBox>
