<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="10" xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.PL.pig_ranch.controller.PendingOrdersController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Button text="← Back" onAction="#handleBackClick" styleClass="btn-secondary"/>
        <Label text="Pending Orders" styleClass="page-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <TextField fx:id="searchField" promptText="Search orders..." prefWidth="250"/>
        <Button text="New Order" onAction="#handleNewOrderClick" styleClass="btn-primary"/>
    </HBox>

    <TableView fx:id="orderTable" VBox.vgrow="ALWAYS">
        <placeholder>
            <Label text="No pending orders — all caught up!" styleClass="table-placeholder"/>
        </placeholder>
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
            <TableColumn fx:id="colClient" text="Client" prefWidth="150"/>
            <TableColumn fx:id="colDate" text="Date" prefWidth="150"/>
            <TableColumn fx:id="colType" text="Type" prefWidth="100"/>
            <TableColumn fx:id="colStatus" text="Status" prefWidth="100"/>
            <TableColumn fx:id="colTotal" text="Total" prefWidth="100"/>
            <TableColumn fx:id="colActions" text="Actions" prefWidth="250"/>
        </columns>
    </TableView>
</VBox>
